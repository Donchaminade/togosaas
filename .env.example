# URL de l'API backend PHP (sans slash final).
# En dev avec le serveur PHP integre : http://localhost:8000
VITE_API_URL=http://localhost:8000

# Cle VAPID PUBLIQUE (non secrete) pour les notifications Web Push.
# Doit correspondre a VAPID_PUBLIC_KEY du backend. Laisser vide desactive le push.
VITE_VAPID_PUBLIC_KEY=

# ==========================================================
# TogoSaaS — Hub SaaS du Togo : Configuration Backend (PHP/MySQL)
# Copiez ce fichier en ".env" et adaptez les valeurs.
# ==========================================================

# --- Base de donnees MySQL ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=tch_db
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# --- Securite / JWT ---
# Generez une longue chaine aleatoire (ex: openssl rand -hex 32)
JWT_SECRET=change_me_with_a_long_random_secret_key_please
JWT_ISSUER=tch-api
# Duree de validite du token en secondes (86400 = 24h)
JWT_TTL=86400

# --- Application ---
APP_ENV=local
APP_DEBUG=true
# URL du frontend autorisee pour le CORS (ex: http://localhost:3000)
FRONTEND_URL=http://localhost:3000
# Plusieurs origines en production (frontend Vercel + domaine custom), separees par des virgules :
# FRONTEND_URLS=https://hub.grosbit.com,https://votre-projet.vercel.app

# --- Compte administrateur cree au seed ---
ADMIN_NAME=Chaminade Dondah Adjolou
ADMIN_EMAIL=chaminade.dondah.adjolou@gmail.com
ADMIN_PASSWORD=Admin@1234

# --- Upload (logos communautes) ---
# Taille max en octets (2 Mo)
MAX_UPLOAD_SIZE=2097152

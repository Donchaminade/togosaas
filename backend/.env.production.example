# ==========================================================
# TCH — Backend production (Hostinger @ tch.grosbit.com)
# Copiez en .env sur le serveur et adaptez les valeurs.
# ==========================================================

# --- Base MySQL (Hostinger → Bases de données) ---
DB_HOST=localhost
DB_PORT=3306
DB_NAME=u878418868_tchdb
DB_USER=u878418868_tch
DB_PASS=votre_mot_de_passe_mysql
DB_CHARSET=utf8mb4

# --- Securite / JWT ---
JWT_SECRET=GENEREZ_UNE_CLE_LONGUE_ALEATOIRE_openssl_rand_hex_32
JWT_ISSUER=tch-api
JWT_TTL=86400

# --- Application ---
APP_ENV=production
APP_DEBUG=false

# --- CORS : URL(s) du frontend Vercel (sans slash final) ---
# Remplacez par votre domaine Vercel (custom ou *.vercel.app) :
FRONTEND_URL=https://votre-projet.vercel.app
# Ou plusieurs (preview + domaine custom) :
# FRONTEND_URLS=https://hub.grosbit.com,https://votre-projet.vercel.app

# --- Compte admin initial (seed) ---
ADMIN_NAME=Chaminade Dondah Adjolou
ADMIN_EMAIL=chaminade.dondah.adjolou@gmail.com
ADMIN_PASSWORD=ChangezCeMotDePasse!

# --- Uploads ---
MAX_UPLOAD_SIZE=2097152
MAX_SUPPORT_UPLOAD_SIZE=5242880

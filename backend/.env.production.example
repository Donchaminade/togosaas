# ==========================================================
# TogoSaaS — Configuration Backend PRODUCTION (Hostinger)
# Copiez en ".env" sur le serveur et remplacez TOUTES les valeurs sensibles.
# Ne committez jamais le .env reel.
# ==========================================================

# --- Base de donnees MySQL (identifiants Hostinger dedies, JAMAIS root) ---
DB_HOST=localhost
DB_PORT=3306
DB_NAME=uXXXXXXXX_tgsaas
DB_USER=uXXXXXXXX_tgsaas
DB_PASS=__MOT_DE_PASSE_DB_FORT__
DB_CHARSET=utf8mb4

# --- Securite / JWT ---
# Generez : openssl rand -hex 32
JWT_SECRET=__REMPLACER_PAR_UNE_CHAINE_ALEATOIRE_DE_64_CARACTERES__
JWT_ISSUER=tch-api
JWT_TTL=86400

# --- Application ---
APP_ENV=production
# IMPERATIF en prod : evite toute fuite de messages SQL/techniques.
APP_DEBUG=false

# --- CORS ---
# Origine principale du frontend (sans slash final).
FRONTEND_URL=https://togosaas.vercel.app
# Listez ici toutes les origines front autorisees (Vercel, previews, domaine custom), separees par des virgules.
FRONTEND_URLS=https://togosaas.vercel.app

# --- Migrations via HTTP (Hostinger sans SSH) ---
# Token DEDIE et long (min. 16 car., ideal 32+). A regenerer et le fichier
# public/run-migrations.php a SUPPRIMER apres chaque migration.
MIGRATE_TOKEN=__TOKEN_MIGRATION_LONG_ET_UNIQUE__

# --- Compte administrateur cree au seed ---
ADMIN_NAME=Chaminade Dondah Adjolou
ADMIN_EMAIL=chaminade.dondah.adjolou@gmail.com
ADMIN_PASSWORD=__MOT_DE_PASSE_ADMIN_FORT__

# --- Upload (logos / images) ---
MAX_UPLOAD_SIZE=2097152
# Taille max des pieces jointes des campagnes email (10 Mo).
MAX_EMAIL_UPLOAD_SIZE=10485760

# --- Envoi d'emails (SMTP Hostinger) ---
# Creez une boite dediee dans hPanel (ex: no-reply@grosbit.com) puis renseignez :
#   MAIL_HOST=smtp.hostinger.com  MAIL_PORT=465  MAIL_ENCRYPTION=ssl
# IMPORTANT : configurez SPF + DKIM sur le domaine pour eviter le spam.
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=465
MAIL_USERNAME=no-reply@grosbit.com
MAIL_PASSWORD=__MOT_DE_PASSE_BOITE_EMAIL__
MAIL_ENCRYPTION=ssl
MAIL_FROM_EMAIL=no-reply@grosbit.com
MAIL_FROM_NAME=TogoSaaS

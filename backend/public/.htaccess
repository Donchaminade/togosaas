<IfModule mod_rewrite.c>
    RewriteEngine On

    # Transmet le header Authorization (sinon perdu par certains serveurs).
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # Sert directement les fichiers/dossiers existants (ex: uploads).
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Tout le reste passe par le front controller.
    RewriteRule ^ index.php [QSA,L]
</IfModule>

# Bloque l'acces aux fichiers sensibles si presents par erreur.
<FilesMatch "^\.env">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
</FilesMatch>

<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
</IfModule>
